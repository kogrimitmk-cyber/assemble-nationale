# ═══════════════════════════════════════════════════
# CONFIGURATION — Assemblée Nationale du Tchad
# ═══════════════════════════════════════════════════
# ⚠️ IMPORTANT : Ne JAMAIS partager ce fichier publiquement.
# Sur l'hébergeur (Render/Railway), ces valeurs se définissent
# dans la section "Environment Variables" de votre projet,
# PAS dans ce fichier (qui ne doit pas être uploadé).

# Port d'écoute du serveur (l'hébergeur le définit souvent automatiquement)
PORT=3000

# Clé secrète pour signer les sessions (cookies de connexion)
# ⚠️ Changez cette valeur avant la mise en ligne ! Générez une chaîne
# aléatoire longue, par exemple avec : openssl rand -hex 32
SESSION_SECRET=changez-cette-cle-secrete-avant-mise-en-ligne-1234567890abcdef

# Environnement : "development" ou "production"
NODE_ENV=development

# Mot de passe administrateur initial (pour le premier compte Secrétaire général)
# Sera utilisé une seule fois lors de l'initialisation de la base de données
ADMIN_INIT_PASSWORD=ChangezMoi2025!
