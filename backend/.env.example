# ═══════════════════════════════════════════════════════════════
# Configuration backend — AN Connect Tchad
# Copiez ce fichier en « .env » et adaptez les valeurs.
# Ne jamais committer le vrai .env.
# ═══════════════════════════════════════════════════════════════

# Clé secrète Django (générez-en une longue et aléatoire en production)
SECRET_KEY=dev-cle-non-securisee-a-changer-en-production

# Mode debug : True en développement, False en production
DEBUG=True

# Hôtes autorisés (séparés par des virgules) en production
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ──────────────────────────────────────────
# Vide  → SQLite local (db.sqlite3), aucun serveur à installer.
# Prod  → PostgreSQL, ex :
# DATABASE_URL=postgres://user:motdepasse@localhost:5432/anconnect
DATABASE_URL=

# ── CORS : origines autorisées (React + Expo) ────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081,http://localhost:19006

# Mot de passe initial des comptes créés par « seed_demo »
ADMIN_INIT_PASSWORD=ChangezMoi2025!
