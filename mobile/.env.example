# URL de l'API Django consommée par l'app.
# Laissez vide pour utiliser la valeur par défaut selon la plateforme :
#   • émulateur Android → http://10.0.2.2:8010
#   • simulateur iOS    → http://localhost:8010
# Sur un TÉLÉPHONE PHYSIQUE (Expo Go), mettez l'IP LAN de votre PC :
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8010
EXPO_PUBLIC_API_URL=
